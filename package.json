{
  "name": "brainsort",
  "main": "expo/AppEntry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "generate:api-types": "openapi-typescript https://brainsort-api.railway.app/api/docs-json --output src/generated/api-types.ts",
    "generate:api-types:local": "openapi-typescript http://localhost:3000/api/docs-json --output src/generated/api-types.ts",
    "prepare": "husky"
  },
  "dependencies": {
    "@expo/metro-runtime": "~3.2.3",
    "@react-navigation/bottom-tabs": "^6.0.0",
    "@react-navigation/native": "^6.0.0",
    "@react-navigation/native-stack": "^6.0.0",
    "@tanstack/react-query": "^5.0.0",
    "d3-interpolate": "^3.0.0",
    "d3-scale": "^4.0.0",
    "expo": "~51.0.0",
    "expo-file-system": "~17.0.0",
    "expo-font": "~12.0.0",
    "expo-secure-store": "~13.0.0",
    "expo-sqlite": "~14.0.0",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-native": "0.74.5",
    "react-native-safe-area-context": "4.10.5",
    "react-native-screens": "3.31.1",
    "react-native-svg": "^15.0.0",
    "react-native-web": "~0.19.10",
    "react-native-webview": "^13.0.0"
  },
  "devDependencies": {
    "@types/d3-interpolate": "^3.0.4",
    "@types/d3-scale": "^4.0.9",
    "@types/react": "~18.2.0",
    "eslint": "^8.57.0",
    "eslint-config-expo": "~8.0.0",
    "husky": "^9.1.7",
    "openapi-typescript": "^7.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.0.0"
  },
  "private": true
}
